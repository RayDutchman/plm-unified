# ============================================================
# PLM Unified 配置模板
# ============================================================
# 复制此文件为 .env，修改后执行 docker-compose up -d

# Nginx 宿主机映射端口
NGINX_HOST_PORT=8080

# PostgreSQL 数据库数据目录（宿主机路径，放在项目外面）
PGDATA_HOST_PATH=../plm_data/pgdata

# 附件上传文件存储目录（宿主机路径）
UPLOADS_HOST_PATH=../plm_data/uploads

# ============================================================
# 安全密钥（必填 - 启动前请生成强随机值）
# ============================================================
# 生成方式：openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars-long
# 生成方式：openssl rand -base64 24
REDIS_PASSWORD=change-me-to-a-random-password

# ============================================================
# AI 助手配置（M6 启用，可选）
# ============================================================
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# ASSISTANT_MAX_ITERS=8
# ASSISTANT_BOM_RAW_THRESHOLD=200
# ASSISTANT_API_MAX_CHARS=8000
# ASSISTANT_API_TIMEOUT=15
